generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  USER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdTasks  Task[] @relation("CreatedTasks")
  assignedTasks Task[] @relation("AssignedTasks")
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  creatorId   Int
  assignedTo  Int?

  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  creator  User  @relation("CreatedTasks", fields: [creatorId], references: [id])
  assignee User? @relation("AssignedTasks", fields: [assignedTo], references: [id])

  playbookId  Int?
  playbook    Playbook? @relation(fields: [playbookId], references: [id])

  @@index([status])
  @@index([assignedTo])
  @@index([deletedAt])
}

model Playbook {
  id              Int        @id @default(autoincrement())
  title           String
  contentMarkdown String     @db.Text
  webhookUrl      String
  triggerState    TaskStatus

  tasks           Task[]

  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}
